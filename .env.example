# Variables de entorno del backend
#
# Como obtener URI_DB en MongoDB Atlas:
# 1) Crea una cuenta en https://www.mongodb.com/atlas y un cluster.
# 2) En Atlas, ve a Security > Database Access y crea un usuario con password.
# 3) Ve a Security > Network Access y agrega tu IP actual (o 0.0.0.0/0 para pruebas).
# 4) En tu cluster, pulsa Connect > Drivers.
# 5) Copia la cadena "mongodb+srv://..." y reemplaza <db_user> y <db_password>.
# 6) Reemplaza <database_name> por el nombre de tu base (ejemplo: ruteando).
#
# Ejemplo:
URI_DB=mongodb+srv://<db_user>:<db_password>@cluster0.xxxxx.mongodb.net/<database_name>?retryWrites=true&w=majority&appName=Cluster0

# Clave para firmar JWT
JWT_SECRET=change_this_secret

# Opcionales para scripts de semillas
SEED_API_URL=http://localhost:3000
SEED_USER_EMAIL=demo.ruteando@example.com
SEED_USER_PASSWORD=Ruteando123!